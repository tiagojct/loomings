{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Loomings",
  "version": "0.2.0",
  "identifier": "app.loomings.mac",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run vite:dev",
    "beforeBuildCommand": "npm run vite:build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Loomings",
        "width": 900,
        "height": 700,
        "minWidth": 500,
        "minHeight": 400,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 14, "y": 18 },
        "backgroundColor": "#0D2F42",
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "category": "public.app-category.productivity",
    "shortDescription": "Minimalist Markdown writing app",
    "longDescription": "The shapes loom before they take form. A minimalist Markdown writing app with focus mode, live preview, and the Pequod theme.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
